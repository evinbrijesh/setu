# Setu — Docker Compose environment variables
# ===========================================
# Copy this to .env and fill in your credentials:
#   cp .env.example .env
#
# Then run:  docker compose up

# ── Sarvam AI ──────────────────────────────────────────────────
# Required by: setu-audio (STT + TTS + LLM), setu-workflows (LLM extraction)
SARVAM_API_KEY=

# ── Supabase ───────────────────────────────────────────────────
# Required by: setu-audio (session lookup, form download), setu-workflows (all tasks)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required by: setu-web (frontend Supabase client, anon key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── WebSocket URL (optional, has default) ─────────────────────
# Tells the frontend where to connect for voice streaming.
# Default in Docker: ws://localhost:8000/ws/audio (host machine → audio container)
# Override if deploying behind a reverse proxy at a different URL.
VITE_AUDIO_WS_URL=ws://localhost:8000/ws/audio
